{
  "name": "war-thunder-stats-backend",
  "version": "2.0.0",
  "description": "Backend API and Admin Dashboard for War Thunder Stats Tracker",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "server:api": "node server.js",
    "server:admin": "node admin-server.js",
    "server:both": "concurrently \"npm run server:api\" \"npm run server:admin\"",
    "dev:api": "nodemon server.js",
    "dev:admin": "NODE_ENV=development node admin-server.js",
    "dev:both": "concurrently \"npm run dev:api\" \"npm run dev:admin\"",
    "build:admin": "cd admin && npm run build",
    "init-db": "node scripts/initDatabase.js",
    "seed": "node scripts/seedData.js",
    "admin": "cd admin && npm start"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "war-thunder",
    "gaming",
    "statistics",
    "api",
    "backend",
    "admin"
  ],
  "author": "War Thunder Stats Backend",
  "license": "MIT"
}
