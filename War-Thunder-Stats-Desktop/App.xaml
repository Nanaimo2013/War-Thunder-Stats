<Application x:Class="WTBattleTracker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnExplicitShutdown">

    <Application.Resources>

        <!-- ── Color palette ─────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgVoid"       Color="#070a0d"/>
        <SolidColorBrush x:Key="BgDeep"       Color="#0d1117"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#111820"/>
        <SolidColorBrush x:Key="BgRaised"     Color="#161e28"/>
        <SolidColorBrush x:Key="BgCard"       Color="#1a2233"/>
        <SolidColorBrush x:Key="BgHover"      Color="#1f2a3d"/>
        <SolidColorBrush x:Key="Amber"        Color="#f59e0b"/>
        <SolidColorBrush x:Key="AmberDim"     Color="#b45309"/>
        <SolidColorBrush x:Key="AmberBright"  Color="#fbbf24"/>
        <SolidColorBrush x:Key="Green"        Color="#22c55e"/>
        <SolidColorBrush x:Key="GreenDim"     Color="#166534"/>
        <SolidColorBrush x:Key="Red"          Color="#ef4444"/>
        <SolidColorBrush x:Key="RedDim"       Color="#991b1b"/>
        <SolidColorBrush x:Key="Blue"         Color="#3b82f6"/>
        <SolidColorBrush x:Key="Purple"       Color="#a855f7"/>
        <SolidColorBrush x:Key="Steel"        Color="#94a3b8"/>
        <SolidColorBrush x:Key="SteelDim"     Color="#475569"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#e2e8f0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#64748b"/>
        <SolidColorBrush x:Key="TextDim"      Color="#94a3b8"/>
        <SolidColorBrush x:Key="Border"       Color="#1f2a3d"/>
        <SolidColorBrush x:Key="BorderAmber"  Color="#292215"/>
        <Color x:Key="AmberColor"             >#f59e0b</Color>
        <Color x:Key="GreenColor"             >#22c55e</Color>
        <Color x:Key="RedColor"               >#ef4444</Color>

        <!-- ── Typography ────────────────────────────────────────────────── -->
        <FontFamily x:Key="DisplayFont">Rajdhani, Segoe UI Semibold, Tahoma</FontFamily>
        <FontFamily x:Key="MonoFont">Consolas, Courier New</FontFamily>
        <FontFamily x:Key="BodyFont">Segoe UI, Tahoma</FontFamily>

        <!-- ── ScrollBar ─────────────────────────────────────────────────── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background"  Value="#0d1117"/>
            <Setter Property="Width"       Value="6"/>
            <Setter Property="Height"      Value="6"/>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility"   Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ── Base TextBlock ─────────────────────────────────────────────── -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"  Value="{StaticResource BodyFont}"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>

        <!-- ── Base Button ────────────────────────────────────────────────── -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Border.CornerRadius" Value="4"/>
            <Setter Property="Padding"       Value="14,8"/>
            <Setter Property="FontFamily"    Value="{StaticResource DisplayFont}"/>
            <Setter Property="FontWeight"    Value="Bold"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Amber primary button -->
        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"   Value="#f59e0b"/>
            <Setter Property="Foreground"   Value="#0d1117"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Ghost / outline button -->
        <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#1f2a3d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#64748b"/>
        </Style>

        <!-- Danger button -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"      Value="#991b1b"/>
            <Setter Property="Foreground"      Value="#fca5a5"/>
            <Setter Property="BorderBrush"     Value="#ef4444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Success button -->
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"      Value="#166534"/>
            <Setter Property="Foreground"      Value="#86efac"/>
            <Setter Property="BorderBrush"     Value="#22c55e"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Small icon button -->
        <Style x:Key="BtnIcon" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#475569"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="11"/>
        </Style>

        <!-- ── TextBox ────────────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"        Value="#1a2233"/>
            <Setter Property="BorderBrush"       Value="#1f2a3d"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Foreground"        Value="#e2e8f0"/>
            <Setter Property="CaretBrush"        Value="#f59e0b"/>
            <Setter Property="SelectionBrush"    Value="#f59e0b"/>
            <Setter Property="Padding"           Value="10,8"/>
            <Setter Property="FontFamily"        Value="{StaticResource BodyFont}"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#f59e0b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox ───────────────────────────────────────────────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#1a2233"/>
            <Setter Property="BorderBrush"     Value="#1f2a3d"/>
            <Setter Property="Foreground"      Value="#e2e8f0"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontFamily"      Value="{StaticResource BodyFont}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <!-- ── ListBox item ───────────────────────────────────────────────── -->
        <Style x:Key="BattleListItem" TargetType="ListBoxItem">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0,0,0,1"/>
            <Setter Property="BorderBrush"      Value="#0d1117"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Margin"           Value="0,0,0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1f2a3d"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#292215"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Separator ──────────────────────────────────────────────────── -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#1f2a3d"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>

    </Application.Resources>

</Application>
