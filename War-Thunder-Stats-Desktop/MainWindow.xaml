<Window x:Class="WTBattleTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WT Battle Tracker"
        MinWidth="1000" MinHeight="640"
        Width="1280" Height="820"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Filter pill toggle button -->
        <Style x:Key="PillBtn" TargetType="ToggleButton">
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#1f2a3d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#64748b"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontFamily"      Value="Rajdhani, Segoe UI Semibold"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background"  Value="#292215"/>
                                <Setter Property="BorderBrush" Value="#f59e0b"/>
                                <Setter Property="Foreground"  Value="#f59e0b"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#b45309"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ── Main chrome with rounded corners ──────────────────────────────── -->
    <Border Background="#0d1117" CornerRadius="10"
            BorderBrush="#1a2830" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.7" ShadowDepth="6" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>   <!-- Title bar -->
                <RowDefinition Height="54"/>   <!-- Status bar -->
                <RowDefinition Height="Auto"/> <!-- Filter bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="38"/>   <!-- Bottom bar -->
            </Grid.RowDefinitions>

            <!-- ── Title bar ────────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#070a0d" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <!-- Logo -->
                        <Border Width="30" Height="30" Background="#f59e0b" CornerRadius="4" Margin="0,0,10,0">
                            <TextBlock Text="W" FontFamily="Rajdhani" FontSize="20" FontWeight="Black"
                                       Foreground="#0d1117" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="WAR THUNDER BATTLE TRACKER"
                                   FontFamily="Rajdhani" FontSize="16" FontWeight="Bold"
                                   Foreground="#f59e0b" VerticalAlignment="Center" LetterSpacing="1"/>
                        <TextBlock Text="  v1.0" FontFamily="Consolas" FontSize="10"
                                   Foreground="#334155" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="BtnMinimize" Content="─" Width="36" Height="28"
                                Style="{StaticResource BtnIcon}" Click="BtnMinimize_Click"
                                FontSize="14" Foreground="#475569"/>
                        <Button x:Name="BtnMaximize" Content="□" Width="36" Height="28"
                                Style="{StaticResource BtnIcon}" Click="BtnMaximize_Click"
                                FontSize="14" Foreground="#475569"/>
                        <Button x:Name="BtnClose" Content="✕" Width="36" Height="28"
                                Style="{StaticResource BtnIcon}" Click="BtnClose_Click"
                                FontSize="13" Foreground="#475569">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BtnIcon}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#991b1b"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Amber accent line under title -->
            <Rectangle Grid.Row="0" Height="2" VerticalAlignment="Bottom">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#f59e0b" Offset="0.3"/>
                        <GradientStop Color="#fbbf24" Offset="0.5"/>
                        <GradientStop Color="#f59e0b" Offset="0.7"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Status bar ─────────────────────────────────────────────── -->
            <Border Grid.Row="1" Background="#0d1117" Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- WT status -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,7,0">
                            <Ellipse.Fill>
                                <SolidColorBrush x:Name="StatusDotColor" Color="#475569"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock x:Name="TxtStatus" Text="WT NOT DETECTED"
                                   FontFamily="Rajdhani" FontSize="11" FontWeight="Bold"
                                   Foreground="#475569" LetterSpacing="1"/>
                    </StackPanel>

                    <!-- Battle timer -->
                    <Border Grid.Column="2"
                            Background="#111820" BorderBrush="#1f2a3d" BorderThickness="1"
                            CornerRadius="4" Padding="12,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚔ " FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtBattleTimer" Text="--:--"
                                       FontFamily="Consolas" FontSize="13" Foreground="#64748b"/>
                        </StackPanel>
                    </Border>

                    <!-- Clipboard / auto status -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                        <TextBlock x:Name="TxtClipStatus" Text="📋 Monitoring Clipboard"
                                   FontFamily="Rajdhani" FontSize="11" Foreground="#334155" Margin="0,0,16,0"/>
                        <Button x:Name="BtnPaste" Content="⊕  PASTE LOG"
                                Style="{StaticResource BtnGhost}"
                                FontFamily="Rajdhani" FontSize="11"
                                Padding="12,5" Click="BtnPaste_Click"
                                ToolTip="Paste a battle log from clipboard manually"/>
                        <Button x:Name="BtnSettings" Content="⚙" Margin="6,0,0,0"
                                Style="{StaticResource BtnIcon}" FontSize="14"
                                Click="BtnSettings_Click" ToolTip="Settings"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Separator line -->
            <Rectangle Grid.Row="1" Height="1" VerticalAlignment="Bottom" Fill="#111820"/>

            <!-- ── Filter bar ──────────────────────────────────────────────── -->
            <Border Grid.Row="2" Background="#0d1117" Padding="14,10">
                <WrapPanel Orientation="Horizontal">
                    <!-- Search box -->
                    <Grid Width="220" Margin="0,0,10,0">
                        <TextBox x:Name="TxtSearch" Padding="32,7,10,7" FontSize="12"
                                 TextChanged="TxtSearch_TextChanged"
                                 ToolTip="Search by mission name, type, or session ID"/>
                        <TextBlock Text="🔍" IsHitTestVisible="False"
                                   Margin="10,0,0,0" FontSize="12"
                                   VerticalAlignment="Center" Foreground="#334155"/>
                    </Grid>

                    <!-- Result filter pills -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                        <ToggleButton x:Name="FilterAll"     Content="ALL"     Style="{StaticResource PillBtn}" Margin="0,0,4,0" IsChecked="True" Click="FilterPill_Click" Tag="All"/>
                        <ToggleButton x:Name="FilterVictory" Content="✓ WIN"   Style="{StaticResource PillBtn}" Margin="0,0,4,0" Click="FilterPill_Click" Tag="Victory">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton" BasedOn="{StaticResource PillBtn}">
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background"  Value="#0f2a1a"/>
                                            <Setter Property="BorderBrush" Value="#22c55e"/>
                                            <Setter Property="Foreground"  Value="#22c55e"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <ToggleButton x:Name="FilterDefeat"  Content="✗ LOSS"  Style="{StaticResource PillBtn}" Margin="0,0,4,0" Click="FilterPill_Click" Tag="Defeat">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton" BasedOn="{StaticResource PillBtn}">
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background"  Value="#2a0f0f"/>
                                            <Setter Property="BorderBrush" Value="#ef4444"/>
                                            <Setter Property="Foreground"  Value="#ef4444"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                    </StackPanel>

                    <!-- Sort combo -->
                    <ComboBox x:Name="CmbSort" Width="160" Margin="0,0,10,0"
                              SelectionChanged="CmbSort_SelectionChanged" VerticalAlignment="Center">
                        <ComboBoxItem Content="Battle Date ↓"  Tag="BattleDate,Desc"  IsSelected="True"/>
                        <ComboBoxItem Content="Battle Date ↑"  Tag="BattleDate,Asc"/>
                        <ComboBoxItem Content="Upload Date ↓"  Tag="ParsedAt,Desc"/>
                        <ComboBoxItem Content="Kills ↓"        Tag="Kills,Desc"/>
                        <ComboBoxItem Content="SL Earned ↓"   Tag="SL,Desc"/>
                        <ComboBoxItem Content="RP Earned ↓"   Tag="RP,Desc"/>
                        <ComboBoxItem Content="Activity ↓"    Tag="Activity,Desc"/>
                    </ComboBox>

                    <!-- Date range -->
                    <DatePicker x:Name="DpFrom" Width="130" Margin="0,0,4,0"
                                SelectedDateChanged="DateFilter_Changed"
                                ToolTip="Battle date from" VerticalAlignment="Center"/>
                    <TextBlock Text="→" VerticalAlignment="Center" Foreground="#334155" Margin="0,0,4,0"/>
                    <DatePicker x:Name="DpTo" Width="130" Margin="0,0,10,0"
                                SelectedDateChanged="DateFilter_Changed"
                                ToolTip="Battle date to" VerticalAlignment="Center"/>

                    <!-- Reset -->
                    <Button Content="↺  RESET" Style="{StaticResource BtnGhost}"
                            FontFamily="Rajdhani" FontSize="11" Padding="10,5"
                            Click="BtnResetFilters_Click" VerticalAlignment="Center"/>
                </WrapPanel>
            </Border>

            <!-- ── Main content area ───────────────────────────────────────── -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" MinWidth="280" MaxWidth="500"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Battle list -->
                <Border Grid.Column="0" Background="#0d1117" BorderBrush="#111820" BorderThickness="0,1,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Stats mini bar -->
                        <Border Grid.Row="0" Background="#070a0d" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="TxtStatBattles" Text="0"
                                               FontFamily="Consolas" FontSize="18" Foreground="#f59e0b" FontWeight="Bold"/>
                                    <TextBlock Text="BATTLES" FontFamily="Rajdhani" FontSize="9"
                                               Foreground="#334155" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="TxtStatWinRate" Text="0%"
                                               FontFamily="Consolas" FontSize="18" Foreground="#22c55e" FontWeight="Bold"/>
                                    <TextBlock Text="WIN RATE" FontFamily="Rajdhani" FontSize="9"
                                               Foreground="#334155" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock x:Name="TxtStatKills" Text="0"
                                               FontFamily="Consolas" FontSize="18" Foreground="#ef4444" FontWeight="Bold"/>
                                    <TextBlock Text="KILLS" FontFamily="Rajdhani" FontSize="9"
                                               Foreground="#334155" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock x:Name="TxtStatSL" Text="0"
                                               FontFamily="Consolas" FontSize="18" Foreground="#f59e0b" FontWeight="Bold"/>
                                    <TextBlock Text="TOTAL SL" FontFamily="Rajdhani" FontSize="9"
                                               Foreground="#334155" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- List -->
                        <ListBox x:Name="BattleList" Grid.Row="1"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="8,4" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource BattleListItem}"
                                 SelectionChanged="BattleList_SelectionChanged"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!-- Battle list card -->
                                    <Border Margin="0,2" CornerRadius="6" Padding="0"
                                            Background="#111820">
                                        <Grid>
                                            <!-- Result indicator strip -->
                                            <Border Width="3" HorizontalAlignment="Left"
                                                    CornerRadius="3,0,0,3">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding ResultColor}"/>
                                                </Border.Background>
                                            </Border>

                                            <StackPanel Margin="10,8,8,8">
                                                <!-- Row 1: Result badge + mission -->
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Left" Margin="0,0,8,0"
                                                            Background="{Binding ResultColor, Converter={StaticResource ColorToBrushConverter}}"
                                                            CornerRadius="3" Padding="5,2">
                                                        <TextBlock Text="{Binding Result}"
                                                                   FontFamily="Rajdhani" FontSize="10"
                                                                   FontWeight="Bold" Foreground="#0d1117"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding MissionName}"
                                                               FontFamily="Rajdhani" FontSize="14"
                                                               FontWeight="Bold" Foreground="#e2e8f0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>

                                                <!-- Row 2: Date + mission type -->
                                                <DockPanel Margin="0,3,0,0">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Text="{Binding DisplayDate}"
                                                               FontFamily="Consolas" FontSize="11"
                                                               Foreground="#64748b" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding MissionType}"
                                                               FontFamily="Consolas" FontSize="10"
                                                               Foreground="#334155"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>

                                                <!-- Row 3: Stats -->
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="⚔ " FontSize="10" Foreground="#475569"/>
                                                    <TextBlock Text="{Binding TotalKills}"
                                                               FontFamily="Consolas" FontSize="12"
                                                               Foreground="#ef4444" Margin="0,0,12,0"/>
                                                    <TextBlock Text="SL " FontFamily="Rajdhani" FontSize="10"
                                                               Foreground="#475569"/>
                                                    <TextBlock Text="{Binding FormattedSL}"
                                                               FontFamily="Consolas" FontSize="12"
                                                               Foreground="#f59e0b" Margin="0,0,12,0"/>
                                                    <TextBlock Text="RP " FontFamily="Rajdhani" FontSize="10"
                                                               Foreground="#475569"/>
                                                    <TextBlock Text="{Binding FormattedRP}"
                                                               FontFamily="Consolas" FontSize="12"
                                                               Foreground="#a855f7"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Drag handle -->
                <GridSplitter Grid.Column="1" Background="#111820" HorizontalAlignment="Stretch"/>

                <!-- Right: Detail panel -->
                <Border Grid.Column="2" Background="#0d1117" Padding="20">
                    <ScrollViewer>
                        <StackPanel x:Name="DetailPanel" Visibility="Collapsed">

                            <!-- ── Battle header ─────────────────────────── -->
                            <Border x:Name="DetailHeader" CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
                                <Border.Background>
                                    <SolidColorBrush x:Name="DetailHeaderBg" Color="#111820"/>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="TxtDetailResult" Text=""
                                                   FontFamily="Rajdhani" FontSize="26"
                                                   FontWeight="Black" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDetailMission" Text=""
                                                   FontFamily="Rajdhani" FontSize="18"
                                                   FontWeight="Bold" Foreground="#e2e8f0" Margin="0,0,0,2"/>
                                        <TextBlock x:Name="TxtDetailType" Text=""
                                                   FontFamily="Consolas" FontSize="11" Foreground="#64748b"/>
                                        <Separator Margin="0,10"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🗓 " FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtDetailDate" Text=""
                                                       FontFamily="Consolas" FontSize="12" Foreground="#94a3b8" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="📤 " FontSize="11" Foreground="#334155" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtDetailParsed" Text=""
                                                       FontFamily="Consolas" FontSize="11" Foreground="#334155" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtDetailSession" Text=""
                                                   FontFamily="Consolas" FontSize="10" Foreground="#1e293b" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <!-- Action buttons -->
                                        <Button x:Name="BtnDeleteSelected" Content="🗑 Delete"
                                                Style="{StaticResource BtnDanger}"
                                                FontFamily="Rajdhani" FontSize="11"
                                                Padding="10,5" Click="BtnDeleteSelected_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- ── Stats grid ──────────────────────────────── -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Combat card -->
                                <Border Grid.Column="0" Background="#111820" CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="COMBAT" FontFamily="Rajdhani" FontSize="10"
                                                   FontWeight="Bold" Foreground="#ef4444" Margin="0,0,0,10"/>
                                        <StackPanel x:Name="CombatStats"/>
                                    </StackPanel>
                                </Border>

                                <!-- Economy card -->
                                <Border Grid.Column="2" Background="#111820" CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="ECONOMY" FontFamily="Rajdhani" FontSize="10"
                                                   FontWeight="Bold" Foreground="#f59e0b" Margin="0,0,0,10"/>
                                        <StackPanel x:Name="EconomyStats"/>
                                    </StackPanel>
                                </Border>

                                <!-- Performance card -->
                                <Border Grid.Column="4" Background="#111820" CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="PERFORMANCE" FontFamily="Rajdhani" FontSize="10"
                                                   FontWeight="Bold" Foreground="#22c55e" Margin="0,0,0,10"/>
                                        <StackPanel x:Name="PerformanceStats"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- ── Kill events ─────────────────────────────── -->
                            <Border x:Name="KillsSection" Background="#111820" CornerRadius="8"
                                    Padding="14" Margin="0,0,0,12" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="KILLS" FontFamily="Rajdhani" FontSize="10"
                                               FontWeight="Bold" Foreground="#ef4444" Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="KillsList"/>
                                </StackPanel>
                            </Border>

                            <!-- ── Awards ──────────────────────────────────── -->
                            <Border x:Name="AwardsSection" Background="#111820" CornerRadius="8"
                                    Padding="14" Margin="0,0,0,12" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="AWARDS &amp; DECORATIONS" FontFamily="Rajdhani" FontSize="10"
                                               FontWeight="Bold" Foreground="#f59e0b" Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="AwardsList"/>
                                </StackPanel>
                            </Border>

                            <!-- ── Research ────────────────────────────────── -->
                            <Border x:Name="ResearchSection" Background="#111820" CornerRadius="8"
                                    Padding="14" Margin="0,0,0,12" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="RESEARCH" FontFamily="Rajdhani" FontSize="10"
                                               FontWeight="Bold" Foreground="#a855f7" Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="ResearchList"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── Bottom action bar ──────────────────────────────────────── -->
            <Border Grid.Row="4" Background="#070a0d" CornerRadius="0,0,10,10"
                    Padding="14,0" BorderBrush="#111820" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: info -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtBattleCount" Text="0 battles"
                                   FontFamily="Consolas" FontSize="11" Foreground="#334155" Margin="0,0,16,0"/>
                        <TextBlock x:Name="TxtLastUpdate" Text=""
                                   FontFamily="Consolas" FontSize="10" Foreground="#1e293b" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: actions -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnClearAll" Content="🗑 Clear All"
                                Style="{StaticResource BtnGhost}"
                                FontFamily="Rajdhani" FontSize="11" Padding="10,4"
                                Margin="0,0,6,0" Click="BtnClearAll_Click"/>
                        <Button x:Name="BtnExport" Content="⬇  EXPORT FOR WEBSITE"
                                Style="{StaticResource BtnPrimary}"
                                FontFamily="Rajdhani" FontSize="12" Padding="16,5"
                                Click="BtnExport_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
